{
  "name": "el-patron-gestor-gastronomico",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); for (const path of ['dist']) fs.rmSync(path,{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "check:recetas": "tsx scripts/check-recetas-module.ts",
    "check:deploy-config": "tsx scripts/check-deploy-config.ts",
    "verify": "npm run lint && npm test && npm run check:recetas && npm run check:deploy-config && npm run build",
    "prepush": "npm run lint && npm run check:recetas && npm run build",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@arcasdk/core": "^1.3.1",
    "@arcasdk/pdf": "^0.2.0",
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-window": "^2.2.7",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.16"
  }
}
