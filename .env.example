# Supabase credentials used by the browser app.
# Copy this file to .env.local and fill in your own project values.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Configure separately in Vercel for Production, Preview and Development.
# Production deployments require Supabase variables and demo login disabled.
VITE_ENABLE_DEMO_LOGIN="true"
VITE_DEMO_USER=""
VITE_DEMO_PASSWORD=""
